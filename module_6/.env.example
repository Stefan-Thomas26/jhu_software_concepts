# Copy this file to .env and fill in your PostgreSQL credentials
DB_HOST=localhost
DB_PORT=5432
DB_NAME=applicantdata
DB_USER=gradcafe_reader
DB_PASSWORD=your_actual_password
DATA_FILE=src/data/llm_extended_applicant_data.json
DATA_DIR=src/data

# Local pytest DB connection (used outside Docker)
DATABASE_URL=postgresql://gradcafe_reader:your_actual_password@localhost:5432/testdb

# Docker Compose / RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
FLASK_SECRET=gradcafe_setup_key
FLASK_ENV=development